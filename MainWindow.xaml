<Window x:Class="CyberSecurityChatBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔒 CYBERSECURITY AWARENESS BOT 🔒"
        Height="700"
        Width="1100"
        MinHeight="600"
        MinWidth="900"
        Background="#FFF8F0F5"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- ============================================ -->
        <!-- LEFT PANEL: CHAT SECTION -->
        <!-- ============================================ -->
        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" 
                    Background="HotPink" 
                    Padding="10" 
                    CornerRadius="5" 
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="🔒 CYBERSECURITY AWARENESS BOT 🔒"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" 
                               Text="Ready to help you stay safe online!"
                               FontSize="12"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Opacity="0.8"/>
                </StackPanel>
            </Border>

            <!-- Chat Display with SCROLLING -->
            <Border Grid.Row="1" 
                    Background="White" 
                    CornerRadius="5" 
                    Padding="5">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ListBox x:Name="ChatListBox"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="14"
                             AutomationProperties.Name="Chat Messages">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="5" Padding="8" CornerRadius="8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E3F2FD"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Sender}" Value="You">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Sender}" Value="Bot">
                                                    <Setter Property="Background" Value="#FFF3E0"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock FontWeight="Bold">
                                            <Run Text="{Binding Sender}"/>
                                            <Run Text=" "/>
                                            <Run Text="["/>
                                            <Run Text="{Binding Timestamp}"/>
                                            <Run Text="]"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Message}" 
                                                   TextWrapping="Wrap" 
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Border>

            <!-- Input Area -->
            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Type your message:" 
                               FontSize="12" 
                               Foreground="#666" 
                               Margin="0,0,0,2"/>
                    <TextBox x:Name="UserInput" 
                             Height="40"
                             FontSize="14"
                             Padding="10,8,10,8"
                             Background="White"
                             BorderBrush="#DDD"
                             BorderThickness="1"
                             AutomationProperties.Name="Message Input"
                             KeyDown="UserInput_KeyDown"/>
                </StackPanel>

                <Button x:Name="SendButton" 
                        Grid.Column="1"
                        Content="Send"
                        Height="40"
                        Width="80"
                        Margin="5,18,0,0"
                        Background="HotPink"
                        Foreground="White"
                        FontWeight="Bold"
                        FontSize="14"
                        AutomationProperties.Name="Send Message"
                        Click="SendButton_Click"/>
            </Grid>
        </Grid>

        <!-- ============================================ -->
        <!-- RIGHT PANEL: TASK ASSISTANT & FEATURES -->
        <!-- ============================================ -->
        <Grid Grid.Column="1" Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Task Assistant Header -->
            <Border Grid.Row="0" 
                    Background="#9C27B0" 
                    Padding="10" 
                    CornerRadius="5" 
                    Margin="0,0,0,10">
                <TextBlock Text="📋 Task Assistant" 
                           Foreground="White" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Task Input Fields -->
            <Border Grid.Row="1" 
                    Background="White" 
                    Padding="10" 
                    CornerRadius="5" 
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Task Title" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,2"/>
                    <TextBox x:Name="TaskTitleBox" 
                             Height="30" 
                             FontSize="12" 
                             Padding="5,4,5,4"
                             Margin="0,0,0,5"
                             AutomationProperties.Name="Task Title Input"/>

                    <TextBlock Text="Description (optional)" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,2"/>
                    <TextBox x:Name="TaskDescriptionBox" 
                             Height="30" 
                             FontSize="12" 
                             Padding="5,4,5,4"
                             Margin="0,0,0,5"
                             AutomationProperties.Name="Task Description Input"/>

                    <TextBlock Text="Reminder (optional)" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Margin="0,0,0,2"/>
                    <TextBox x:Name="TaskReminderBox" 
                             Height="30" 
                             FontSize="12" 
                             Padding="5,4,5,4"
                             Margin="0,0,0,5"
                             AutomationProperties.Name="Task Reminder Input"/>

                    <Button x:Name="AddTaskButton" 
                            Content="➕ Add Task" 
                            Height="35"
                            Background="#9C27B0"
                            Foreground="White"
                            FontWeight="Bold"
                            AutomationProperties.Name="Add New Task"
                            Click="AddTaskButton_Click"/>
                </StackPanel>
            </Border>

            <!-- Task List -->
            <Border Grid.Row="2" 
                    Background="White" 
                    Padding="5" 
                    CornerRadius="5" 
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" 
                               Text="📌 Your Tasks" 
                               FontWeight="Bold" 
                               Margin="0,0,0,5"
                               Foreground="#9C27B0"/>

                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="150">
                        <ListBox x:Name="TaskListBox" 
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontSize="12"
                                 AutomationProperties.Name="Task List">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="2" 
                                            Padding="5" 
                                            CornerRadius="3" 
                                            BorderBrush="#DDD" 
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock FontWeight="Bold">
                                                <Run Text="{Binding Title}"/>
                                                <Run Text=" "/>
                                                <!-- Show status as text instead of using converter -->
                                                <Run Text="{Binding IsComplete, StringFormat={}{0}}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Description}" 
                                                       FontSize="10" 
                                                       Foreground="#666"/>
                                            <TextBlock Text="{Binding Reminder}" 
                                                       FontSize="10" 
                                                       Foreground="#9C27B0"/>
                                            <TextBlock Text="{Binding CreatedAt}" 
                                                       FontSize="8" 
                                                       Foreground="#999"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Task Action Buttons -->
            <Grid Grid.Row="3" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="CompleteTaskButton" 
                        Grid.Column="0"
                        Content="✅ Complete"
                        Height="30"
                        Margin="0,0,5,0"
                        Background="#4CAF50"
                        Foreground="White"
                        FontWeight="Bold"
                        AutomationProperties.Name="Complete Selected Task"
                        Click="CompleteTaskButton_Click"/>

                <Button x:Name="DeleteTaskButton" 
                        Grid.Column="1"
                        Content="🗑️ Delete"
                        Height="30"
                        Margin="5,0,0,0"
                        Background="#F44336"
                        Foreground="White"
                        FontWeight="Bold"
                        AutomationProperties.Name="Delete Selected Task"
                        Click="DeleteTaskButton_Click"/>
            </Grid>

            <!-- Quick Action Buttons -->
            <Border Grid.Row="4" 
                    Background="#F5F5F5" 
                    Padding="10" 
                    CornerRadius="5" 
                    Margin="0,0,0,5">
                <StackPanel>
                    <TextBlock Text="⚡ Quick Actions" 
                               FontWeight="Bold" 
                               Margin="0,0,0,5" 
                               Foreground="#9C27B0"/>
                    <WrapPanel>
                        <Button x:Name="StartQuizButton" 
                                Content="🎯 Start Quiz"
                                Height="30"
                                Margin="0,0,5,5"
                                Background="#FF9800"
                                Foreground="White"
                                FontWeight="Bold"
                                AutomationProperties.Name="Start Cybersecurity Quiz"
                                Click="StartQuizButton_Click"/>

                        <Button x:Name="ShowLogButton" 
                                Content="📊 Activity Log"
                                Height="30"
                                Margin="0,0,5,5"
                                Background="#2196F3"
                                Foreground="White"
                                FontWeight="Bold"
                                AutomationProperties.Name="Show Activity Log"
                                Click="ShowLogButton_Click"/>

                        <Button x:Name="RefreshTasksButton" 
                                Content="🔄 Refresh"
                                Height="30"
                                Margin="0,0,5,5"
                                Background="#607D8B"
                                Foreground="White"
                                FontWeight="Bold"
                                AutomationProperties.Name="Refresh Task List"
                                Click="RefreshTasksButton_Click"/>

                        <Button x:Name="ClearChatButton" 
                                Content="🧹 Clear Chat"
                                Height="30"
                                Margin="0,0,5,5"
                                Background="#F44336"
                                Foreground="White"
                                FontWeight="Bold"
                                AutomationProperties.Name="Clear Chat Messages"
                                Click="ClearChatButton_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Status Bar -->
            <Border Grid.Row="5" 
                    Background="#E0E0E0" 
                    Padding="5" 
                    CornerRadius="3">
                <TextBlock x:Name="TaskCountText" 
                           Text="Tasks: 0 | Ready"
                           FontSize="10"
                           Foreground="#666"
                           HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</Window>